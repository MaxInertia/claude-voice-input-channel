#!/bin/bash
# install-systemd-units — render and install the voice-stt systemd user
# units for this checkout.
#
# Idempotent. Re-running overwrites the existing unit files with the
# current checkout path and re-executes daemon-reload.
#
# After this script runs, manage the services with either:
#
#     systemctl --user start|stop|restart|status voice-sttd.service
#     systemctl --user start|stop|restart|status voice-stt-ptt.service
#
# or via the voice-stt-svc wrapper (which now forwards to systemctl).

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
TEMPLATE_DIR="$PROJECT_DIR/scripts/systemd"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

# Sanity checks before we write anything.
if [[ ! -f "$TEMPLATE_DIR/voice-sttd.service.in" ]]; then
    echo "error: $TEMPLATE_DIR/voice-sttd.service.in not found — is this repo complete?" >&2
    exit 1
fi
if ! command -v systemctl >/dev/null 2>&1; then
    echo "error: systemctl not found — this script only works on systemd systems" >&2
    exit 1
fi
if ! command -v "$HOME/.local/bin/uv" >/dev/null 2>&1 && ! command -v uv >/dev/null 2>&1; then
    echo "warning: uv not found at ~/.local/bin/uv or on PATH — the units reference" >&2
    echo "         ~/.local/bin/uv explicitly. Install uv before starting the service." >&2
fi

mkdir -p "$UNIT_DIR"

for src in "$TEMPLATE_DIR"/*.service.in; do
    name="$(basename "${src%.in}")"
    dst="$UNIT_DIR/$name"
    sed "s|@VOICE_STT_ROOT@|$PROJECT_DIR|g" "$src" > "$dst"
    echo "installed: $dst"
done

systemctl --user daemon-reload
echo "daemon-reload: ok"

cat <<EOF

Units installed. Start them now with:

    systemctl --user enable --now voice-sttd.service voice-stt-ptt.service

Check status:

    systemctl --user status voice-sttd.service
    journalctl --user -u voice-sttd.service -f

If this is a fresh system, you may want to enable lingering so the
services keep running after you log out (useful if you leave a Claude
Code session open across SSH disconnects):

    loginctl enable-linger \$USER

EOF
