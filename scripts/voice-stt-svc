#!/usr/bin/env bash
# voice-stt-svc — start/stop the voice-stt daemon + PTT listener as a pair.
#
#   voice-stt-svc start    launch voice-sttd and voice-stt-ptt in the background
#   voice-stt-svc stop     kill them both, clean up sockets
#   voice-stt-svc status   show whether each is running
#   voice-stt-svc restart  stop then start
#   voice-stt-svc logs     tail both log files
#
# Logs: /tmp/voice-stt-{daemon,ptt}.log

set -uo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
RUN_DIR="${VOICE_STT_RUN_DIR:-/tmp}"
DAEMON_LOG="$RUN_DIR/voice-stt-daemon.log"
PTT_LOG="$RUN_DIR/voice-stt-ptt.log"
SOCKET_DIR="${XDG_RUNTIME_DIR:-/tmp}/voice-stt"
CTRL_SOCK="$SOCKET_DIR/ctrl.sock"
OUT_SOCK="$SOCKET_DIR/out.sock"

DAEMON_PAT='voice_stt\.daemon|/voice-sttd'
PTT_PAT='voice_stt\.ptt_listener|/voice-stt-ptt'

# --- .env loading ----------------------------------------------------------
# Load $PROJECT_DIR/.env if present. Shell env vars already exported take
# precedence — .env only fills in values that aren't already set. This means
# one-off overrides work without editing .env:
#
#     VOICE_STT_MODEL=small.en voice-stt-svc restart
#
# See .env.example for the full list of supported keys.
ENV_FILE="$PROJECT_DIR/.env"
if [[ -f "$ENV_FILE" ]]; then
    # Tighten permissions to 0600 so other local users can't read secrets
    # you might later add to .env. Only act if the perms are loose today —
    # skip the chmod if it's already tight to avoid touching files we don't
    # need to and to avoid surprising people who intentionally group-share.
    current_mode=$(stat -c '%a' "$ENV_FILE" 2>/dev/null || echo "")
    if [[ -n "$current_mode" && "$current_mode" != "600" && "$current_mode" != "400" ]]; then
        chmod 600 "$ENV_FILE" 2>/dev/null \
            && echo "voice-stt-svc: tightened $ENV_FILE permissions to 0600 (was $current_mode)" >&2
    fi

    while IFS= read -r line || [[ -n "$line" ]]; do
        # skip comments and blank lines
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        # strip optional leading `export `
        line="${line#export }"
        # split on first =
        key="${line%%=*}"
        val="${line#*=}"
        # trim whitespace around key
        key="${key// /}"
        key="${key//$'\t'/}"
        [[ -z "$key" ]] && continue
        # only allow sensible identifier-shaped keys — blocks accidental
        # or malicious injection if someone drops a weird line into .env
        [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
        # strip surrounding quotes from value
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        # only set if not already in the shell environment
        if [[ -z "${!key+x}" ]]; then
            export "$key=$val"
        fi
    done < "$ENV_FILE"
fi

# --- propagate VOICE_STT_* env to child processes --------------------------
# The daemon reads all of these via os.environ.get() — including the
# PULSE_SOURCE bridge — so we just need to export whatever .env populated
# (or left unset, letting the daemon's builtin defaults apply).
for var in VOICE_STT_MODEL VOICE_STT_COMPUTE_DEVICE VOICE_STT_COMPUTE_TYPE \
           VOICE_STT_INPUT_DEVICE VOICE_STT_PULSE_SOURCE VOICE_STT_PTT_KEY; do
    [[ -n "${!var+x}" ]] && export "$var"
done

UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
HAVE_SYSTEMD_UNITS=0
if command -v systemctl >/dev/null 2>&1 \
   && [[ -f "$UNIT_DIR/voice-sttd.service" ]] \
   && [[ -f "$UNIT_DIR/voice-stt-ptt.service" ]]; then
    HAVE_SYSTEMD_UNITS=1
fi

# --- systemd forwarding (preferred path) -----------------------------------
# If the user ran scripts/install-systemd-units, forward everything to
# systemctl --user. This is the canonical way to manage the services and
# gives you journal integration, restart-on-failure, proper PIDs, and no
# pgrep-self-match bug class.
_systemctl_cmd() {
    local cmd=$1
    case "$cmd" in
        start|stop|restart)
            systemctl --user "$cmd" voice-sttd.service voice-stt-ptt.service
            ;;
        status)
            systemctl --user status --no-pager voice-sttd.service voice-stt-ptt.service
            ;;
        logs)
            exec journalctl --user -u voice-sttd.service -u voice-stt-ptt.service -f
            ;;
    esac
}

# --- legacy fallback -------------------------------------------------------
# Only runs when systemd units aren't installed. Keeps a working voice-stt
# on systems without systemd (rare) or before the user has run
# install-systemd-units. This path has known papercuts (pgrep self-match,
# no restart-on-failure, no journal) — migrate to systemd when you can.
UV="${UV:-$HOME/.local/bin/uv}"
[[ -x "$UV" ]] || UV="$(command -v uv || true)"

_pids() { pgrep -f "$1" 2>/dev/null; }
_running() { [[ -n "$(_pids "$1")" ]]; }

_legacy_start() {
    local name=$1 pat=$2 cmd=$3 logfile=$4
    if _running "$pat"; then
        echo "$name: already running (pid $(_pids "$pat" | tr '\n' ' '))"
        return
    fi
    [[ -x "$UV" ]] || { echo "uv not found; set UV=/path/to/uv" >&2; return 1; }
    cd "$PROJECT_DIR"
    nohup bash -c "exec $cmd" >"$logfile" 2>&1 </dev/null &
    disown
    sleep 0.2
    if _running "$pat"; then
        echo "$name: started (pid $(_pids "$pat" | tr '\n' ' ')) → $logfile"
    else
        echo "$name: failed to start — see $logfile"
        return 1
    fi
}

_legacy_stop() {
    local name=$1 pat=$2
    local pids; pids=$(_pids "$pat")
    if [[ -z "$pids" ]]; then
        echo "$name: not running"
        return
    fi
    # shellcheck disable=SC2086
    kill -TERM $pids 2>/dev/null || true
    for _ in 1 2 3 4 5; do
        _running "$pat" || break
        sleep 0.2
    done
    pids=$(_pids "$pat")
    if [[ -n "$pids" ]]; then
        # shellcheck disable=SC2086
        kill -KILL $pids 2>/dev/null || true
    fi
    echo "$name: stopped"
}

_legacy() {
    case "$1" in
        start)
            _legacy_start daemon "$DAEMON_PAT" "$UV run voice-sttd" "$DAEMON_LOG" || exit 1
            for _ in $(seq 1 100); do
                [[ -S "$CTRL_SOCK" ]] && break
                sleep 0.1
            done
            if [[ ! -S "$CTRL_SOCK" ]]; then
                echo "warning: daemon control socket never appeared — check $DAEMON_LOG"
            fi
            _legacy_start ptt "$PTT_PAT" "$UV run voice-stt-ptt" "$PTT_LOG"
            ;;
        stop)
            _legacy_stop ptt "$PTT_PAT"
            _legacy_stop daemon "$DAEMON_PAT"
            rm -f "$CTRL_SOCK" "$OUT_SOCK"
            ;;
        status)
            for pair in "daemon $DAEMON_PAT" "ptt $PTT_PAT"; do
                n=${pair%% *}
                p=${pair#* }
                pids=$(_pids "$p")
                if [[ -n "$pids" ]]; then
                    echo "$n: running (pid $(echo "$pids" | tr '\n' ' '))"
                else
                    echo "$n: stopped"
                fi
            done
            ;;
        restart)
            _legacy stop
            _legacy start
            ;;
        logs)
            exec tail -F "$DAEMON_LOG" "$PTT_LOG"
            ;;
    esac
}

case "${1:-}" in
    start|stop|restart|status|logs)
        if (( HAVE_SYSTEMD_UNITS )); then
            _systemctl_cmd "$1"
        else
            echo "voice-stt-svc: systemd units not installed, using legacy supervisor." >&2
            echo "               install with: $PROJECT_DIR/scripts/install-systemd-units" >&2
            _legacy "$1"
        fi
        ;;
    *)
        echo "usage: $0 {start|stop|restart|status|logs}" >&2
        exit 2
        ;;
esac
